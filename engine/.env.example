# Aether Engine Environment Configuration
# Copy this to .env and fill in your values

# Claude API Key (required for Claude provider)
AETHER_ANTHROPIC_API_KEY=

# Ollama URL (auto-detected, only override if non-standard)
# AETHER_OLLAMA_BASE_URL=http://localhost:11434

# Engine Configuration
AETHER_PORT=8420
AETHER_DEBUG=false
AETHER_DEFAULT_PROVIDER=claude
AETHER_DEFAULT_MODEL=claude-sonnet-4-20250514
AETHER_MAX_TOKENS=4096
AETHER_TEMPERATURE=0.7
